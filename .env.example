# =============================================================================
# Agzos Command Center — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# --- Banco de dados (obrigatório) ---
DATABASE_URL=postgresql://usuario:senha@localhost:5432/agzos

# --- API Server (artifacts/api-server) ---
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# --- Auth JWT ---
JWT_SECRET=<gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">
JWT_EXPIRES_IN=7d

# --- Frontend Web (artifacts/agzos-hub) ---
# Rode em porta diferente do api-server
# PORT=5173
# BASE_PATH=/
